# Variables d'environnement pour le déploiement en production
# Copiez ce fichier en .env et remplissez les valeurs

# Clé secrète Django (générez-en une nouvelle pour la production)
DJANGO_SECRET_KEY=votre-clé-secrète-ici

# Mode debug (False en production)
DJANGO_DEBUG=False

# URL de la base de données (fournie par Render)
DATABASE_URL=postgresql://username:password@host:port/database

# Configuration pour Render (décommentez si nécessaire)
# WEB_CONCURRENCY=4
